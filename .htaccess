# Prevent directory browsing
Options -Indexes

# Block access to sensitive files
<FilesMatch "^\.env|^\.git|^\.htaccess">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
